# ============================================================
#  CENTRAL CONNECT — Cấu hình môi trường backend
#  Sao chép file này thành ".env" rồi điền thông tin của bạn
# ============================================================

# Cổng chạy server (mặc định 3000)
PORT=3000

# ── SQL Server Connection ────────────────────────────────────
# Tên server SQL Server của bạn (localhost cho máy local)
DB_SERVER=localhost

# Tên database (đã tạo từ schema.sql)
DB_NAME=CentralConnect

# Xác thực: "windows" (Windows Auth) hoặc "sql" (SQL Auth)
DB_AUTH=windows

# Chỉ cần điền nếu DB_AUTH=sql
DB_USER=sa
DB_PASSWORD=your_password_here

# Cổng SQL Server (mặc định 1433)
DB_PORT=1433

# ── CORS — Cho phép frontend truy cập API ───────────────────
# URL của frontend (dùng * để cho phép tất cả trong dev)
CORS_ORIGIN=*
